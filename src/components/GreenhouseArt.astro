---
// Greenhouse illustration — the page's signature. Flat, friendly, brand greens.
// No external assets; scales cleanly. Decorative, so aria-hidden.
---
<svg class="art" viewBox="0 0 520 460" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Illustration eines Treibhauses mit Hochbeeten">
  <!-- sun -->
  <circle cx="430" cy="78" r="46" fill="#f3deb4"/>
  <circle cx="430" cy="78" r="46" fill="#e2a64e" fill-opacity="0.35"/>

  <!-- ground -->
  <rect x="0" y="392" width="520" height="68" rx="0" fill="#e6ecdb"/>
  <path d="M0 392 H520" stroke="#d8ddcc" stroke-width="2"/>

  <!-- greenhouse body -->
  <g>
    <!-- glass panes background -->
    <path d="M150 392 V196 L260 110 L370 196 V392 Z" fill="#eef5ee"/>
    <!-- frame outline -->
    <path d="M150 392 V196 L260 110 L370 196 V392" stroke="#2f6b43" stroke-width="6" stroke-linejoin="round" fill="none"/>
    <!-- gable ridge accent -->
    <path d="M260 110 V392" stroke="#2f6b43" stroke-width="4"/>
    <!-- glazing bars (mullions) -->
    <path d="M150 250 H370 M150 320 H370" stroke="#9bb59f" stroke-width="2"/>
    <path d="M205 196 V392 M315 196 V392" stroke="#9bb59f" stroke-width="2"/>
    <!-- roof glazing bars -->
    <path d="M205 153 L205 196 M315 153 L315 196 M180 173 L260 173 M340 173 L260 173" stroke="#9bb59f" stroke-width="2"/>
    <!-- door -->
    <rect x="238" y="316" width="44" height="76" rx="3" fill="#dcebe0" stroke="#2f6b43" stroke-width="4"/>
    <circle cx="272" cy="356" r="3" fill="#2f6b43"/>
    <!-- finial -->
    <circle cx="260" cy="100" r="7" fill="#8cc152"/>
  </g>

  <!-- raised beds (Hochbeete) -->
  <g>
    <rect x="60" y="350" width="92" height="46" rx="6" fill="#b07f4e"/>
    <rect x="60" y="350" width="92" height="12" rx="6" fill="#c79666"/>
    <!-- sprouts -->
    <path d="M82 350 C82 332 72 326 70 318 C82 322 86 332 86 350" fill="#6fae3f"/>
    <path d="M104 350 C104 326 96 318 96 304 C110 314 110 332 108 350" fill="#8cc152"/>
    <path d="M128 350 C128 334 120 328 120 318 C132 324 132 338 132 350" fill="#6fae3f"/>
  </g>

  <g>
    <rect x="386" y="358" width="84" height="38" rx="6" fill="#b07f4e"/>
    <rect x="386" y="358" width="84" height="10" rx="6" fill="#c79666"/>
    <path d="M408 358 C408 340 400 334 400 324 C412 330 412 344 412 358" fill="#8cc152"/>
    <path d="M432 358 C432 338 442 332 444 322 C434 330 432 344 432 358" fill="#6fae3f"/>
  </g>

  <!-- a couple of friendly birds -->
  <path d="M120 140 q8 -8 16 0 q8 -8 16 0" stroke="#2f6b43" stroke-width="3" fill="none" stroke-linecap="round"/>
  <path d="M360 60 q6 -6 12 0 q6 -6 12 0" stroke="#2f6b43" stroke-width="3" fill="none" stroke-linecap="round"/>
</svg>
