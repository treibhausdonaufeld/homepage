---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<footer class="site-footer">
  <div class="container site-footer__grid">
    <div>
      <strong style="color:#fff; font-family:var(--font-display);">Treibhaus Donaufeld</strong><br />
      <small>Baugruppe · Wien, 21. Bezirk</small>
    </div>
    <nav class="site-footer__links" aria-label="Rechtliches">
      <a href={base + "/info#kontakt"}>Kontakt</a>
      <a href={base + "/info#impressum"}>Impressum</a>
      <a href={base + "/datenschutz"}>Datenschutz</a>
    </nav>
    <small>© {year} Treibhaus Donaufeld</small>
  </div>
</footer>
