---
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const nav = [
  { href: "/",        label: "Start" },
  { href: "/projekt", label: "Projekt" },
  { href: "/wir",     label: "Wir" },
  { href: "/info",    label: "Info" },
];
const isCurrent = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---
<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="Treibhaus Donaufeld – Startseite">
      <img class="brand__logo" src="/images/logo.png" width="1648" height="649" alt="Treibhaus Donaufeld" />
    </a>

    <div class="header-controls">
      <nav id="primary-nav" class="nav" aria-label="Hauptnavigation">
        {nav.map((item) => (
          <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>{item.label}</a>
        ))}
      </nav>

      <button class="theme-toggle" type="button" aria-label="Zwischen hellem und dunklem Modus wechseln" title="Dunkel-/Hellmodus">
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2"/>
          <path d="M12 1.8v2.4M12 19.8v2.4M4.2 4.2l1.7 1.7M18.1 18.1l1.7 1.7M1.8 12h2.4M19.8 12h2.4M4.2 19.8l1.7-1.7M18.1 5.9l1.7-1.7"/>
        </svg>
      </button>

      <button class="nav-toggle" aria-expanded="false" aria-controls="primary-nav">
        <span aria-hidden="true">☰</span> Menü
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.getElementById("primary-nav");
  toggle?.addEventListener("click", () => {
    const open = nav?.getAttribute("data-open") === "true";
    nav?.setAttribute("data-open", String(!open));
    toggle.setAttribute("aria-expanded", String(!open));
  });

  // Dark-mode toggle. The initial theme is set before paint by the inline
  // script in Base.astro; here we just flip it and remember the choice.
  const themeToggle = document.querySelector(".theme-toggle");
  themeToggle?.addEventListener("click", () => {
    const next = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    try { localStorage.setItem("theme", next); } catch (e) { /* private mode */ }
  });
</script>
