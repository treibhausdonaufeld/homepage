---
import Base from '../layouts/Base.astro';

const fotos = [
  "/images/projekt/DSCF6181.jpg",
  "/images/projekt/DSCF6197.jpg",
  "/images/projekt/IMG_4437.jpg",
  "/images/projekt/IMG_4489-2.jpg",
];

const partner = [
  { src: "/images/partner/schwarzatal-logo2-web.png", name: "Schwarzatal", href: "https://www.schwarzatal.at/" },
  { src: "/images/partner/realitylab-logo-web.png",   name: "realitylab",  href: "https://www.realitylab.at/" },
  { src: "/images/partner/sandbichler-logo-web.png",  name: "Architektur Sandbichler", href: "https://www.sandbichler.at/" },
];
---
<Base title="Wir – Treibhaus Donaufeld" description="Die Menschen hinter dem Treibhaus Donaufeld: eine Baugruppe aus Familien, Paaren, Singles und Senior*innen.">
  <section class="section">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Wir</span>
      <h1>Die Menschen hinter dem Treibhaus</h1>
      <p class="lead" style="margin-top:1rem;">
        Eine bunte Gruppe aus Familien, Paaren, Singles, Studierenden und Senior*innen –
        verbunden durch die Idee von gemeinschaftlichem, leistbarem und nachhaltigem Wohnen.
      </p>
    </div>
    <div class="container">
      <ul class="media-grid media-grid--photos">
        {fotos.map((src) => (
          <li class="media-card media-card--plain">
            <img src={src} alt="Die Baugruppe Treibhaus Donaufeld" loading="lazy" />
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section--mist">
    <div class="container" style="max-width:48rem;">
      <h2>Gemeinsam unterwegs seit 2018</h2>
      <p style="color:var(--ink-soft);">
        Was als kleine Kerngruppe begann, ist über die Jahre zu einer Gemeinschaft gewachsen, die bald
        zusammenzieht. Wir treffen uns regelmäßig, planen zusammen und gestalten unser künftiges Zuhause Stück für Stück.
      </p>
      <div class="btn-row" style="margin-top:1.5rem;">
        <a class="btn btn--primary" href="/info#mitgliedschaft">Mitmachen</a>
        <a class="btn btn--ghost" href="/info#kontakt">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Partner</span>
      <h2>Mit wem wir zusammenarbeiten</h2>
      <p style="color:var(--ink-soft);">
        Das Treibhaus Donaufeld entsteht in Kooperation mit dem Bauträger und unseren Planungspartner*innen.
      </p>
    </div>
    <div class="container">
      <ul class="partner-row">
        {partner.map((p) => (
          <li>
            <a href={p.href} rel="noopener" aria-label={p.name}>
              <img src={p.src} alt={p.name} loading="lazy" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>
