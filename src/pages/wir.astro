---
import Base from '../layouts/Base.astro';
---
<Base title="Wir – Treibhaus Donaufeld" description="Die Menschen hinter dem Treibhaus Donaufeld: eine Baugruppe aus Familien, Paaren, Singles und Senior*innen.">
  <section class="section">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Wir</span>
      <h1>Die Menschen hinter dem Treibhaus</h1>
      <p class="lead" style="margin-top:1rem;">
        Eine bunte Gruppe aus Familien, Paaren, Singles, Studierenden und Senior*innen –
        verbunden durch die Idee von gemeinschaftlichem, leistbarem und nachhaltigem Wohnen.
      </p>
      <!-- TODO: Vorstellungstext und ggf. Fotos der Gruppe aus der alten Seite /wir übernehmen.
           Bilder nach /public/images/ legen und hier einbinden, z.B.:
           <img src="/images/gemeinschaftstag.jpg" alt="Gemeinschaftstag der Baugruppe" /> -->
    </div>
  </section>

  <section class="section section--mist">
    <div class="container" style="max-width:48rem;">
      <h2>Gemeinsam unterwegs seit 2018</h2>
      <p style="color:var(--ink-soft);">
        Was als kleine Kerngruppe begann, ist über die Jahre zu einer Gemeinschaft gewachsen, die bald
        zusammenzieht. Wir treffen uns regelmäßig, planen zusammen und gestalten unser künftiges Zuhause Stück für Stück.
      </p>
      <div class="btn-row" style="margin-top:1.5rem;">
        <a class="btn btn--primary" href="/info#mitgliedschaft">Mitmachen</a>
        <a class="btn btn--ghost" href="/info#kontakt">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</Base>
