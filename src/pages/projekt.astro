---
import Base from '../layouts/Base.astro';
---
<Base title="Projekt – Treibhaus Donaufeld" description="Standort, Angebot, Konzept, Architektur und Organisation der Baugruppe Treibhaus Donaufeld im Wiener Donaufeld.">
  <section class="section">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Das Projekt</span>
      <h1>Treibhaus Donaufeld im Detail</h1>
      <p class="lead" style="margin-top:1rem;">
        Ein neunstöckiges Wohnhaus als Baugruppe – gemeinschaftlich geplant, leistbar und nachhaltig.
        Hier findest du die wichtigsten Bausteine des Projekts.
      </p>
    </div>
  </section>

  <section class="section section--mist" id="auf-einen-blick" aria-labelledby="auf-einen-blick-h">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Auf einen Blick</span>
      <h2 id="auf-einen-blick-h">Das Wichtigste in Kürze</h2>
      <!-- TODO: Inhalt aus der alten Seite /projekt#auf-einen-blick übernehmen -->
      <p style="color:var(--ink-soft);">Kurzüberblick zu Wohnungen, Gemeinschaftsflächen und Grundwerten des Projekts.</p>
    </div>
  </section>

  <section class="section" id="standort" aria-labelledby="standort-h">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Standort</span>
      <h2 id="standort-h">Im Quartier „An der Schanze“</h2>
      <p style="color:var(--ink-soft);">
        Teil des neuen Stadtquartiers „An der Schanze“ im 21. Bezirk – gute öffentliche Anbindung,
        Naherholung und die Alte Donau fußläufig erreichbar.
      </p>
      <p><a href="https://www.iba-wien.at/projekte/projekt-detail/project/donaufeld" rel="noopener">Quartier auf iba-wien.at →</a></p>
      <!-- TODO: Karte/Detailtext aus /projekt#standort übernehmen -->
    </div>
  </section>

  <section class="section section--mist" id="angebot" aria-labelledby="angebot-h">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Angebot</span>
      <h2 id="angebot-h">Wohnungen &amp; Gemeinschaftsräume</h2>
      <!-- TODO: Inhalt aus /projekt#angebot übernehmen -->
      <p style="color:var(--ink-soft);">Überblick über Wohnungsgrößen, Gemeinschaftsflächen und Angebote im Haus.</p>
    </div>
  </section>

  <section class="section" id="konzept" aria-labelledby="konzept-h">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Konzept</span>
      <h2 id="konzept-h">Wie wir leben wollen</h2>
      <ul style="color:var(--ink-soft); padding-left:1.1rem;">
        <li>Fortschrittliches Mobilitätskonzept</li>
        <li>Zusammenarbeit mit umliegenden Baugruppen</li>
        <li>Kooperation mit zahlreichen Vereinen</li>
        <li>Nachhaltigkeit: Fassadenbegrünung, geringe Bodenversiegelung, Lebensraum für Flora und Fauna</li>
      </ul>
    </div>
  </section>

  <section class="section section--mist" id="architektur" aria-labelledby="architektur-h">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Architektur</span>
      <h2 id="architektur-h">Hell, freundlich, gemeinschaftlich</h2>
      <ul style="color:var(--ink-soft); padding-left:1.1rem;">
        <li>Hohe Lebensqualität für Menschen jeden Alters und in allen Lebenslagen</li>
        <li>Hell und freundlich, beiläufige Begegnungen und Gemeinschaft fördernd</li>
        <li>Bedürfnisse nach Gemeinschaft wie auch nach Rückzug werden berücksichtigt</li>
      </ul>
    </div>
  </section>

  <section class="section" id="organisation" aria-labelledby="organisation-h">
    <div class="container" style="max-width:48rem;">
      <span class="eyebrow">Organisation</span>
      <h2 id="organisation-h">Wie wir uns organisieren</h2>
      <!-- TODO: Inhalt aus /projekt#organisation übernehmen -->
      <p style="color:var(--ink-soft);">Aufbau der Baugruppe, Entscheidungsfindung und Zusammenarbeit mit dem Bauträger.</p>
    </div>
  </section>
</Base>
